#!/bin/bash
set -euo pipefail

echo "========================================"
echo "[INFO] Bắt đầu cấu hình 5 node Mysterium (node_1 đến node_5)..."
echo "========================================"

# Vòng lặp chạy từ 1 đến 5
for i in {1..5}; do
    # Cập nhật tên container có thêm chữ "_node_"
    CONTAINER="myst_node_$i"
    echo "[INFO] Đang cấu hình $CONTAINER ..."
    
    # Lệnh set config cho Mysterium
    docker exec "$CONTAINER" myst config set payments.zero-stake-unsettled-amount 1 || true
    
    # Nghỉ 1 giây để tránh nghẽn tiến trình của Docker
    sleep 1
done

echo "----------------------------------------"
echo "[INFO] Đang Restart 5 node để áp dụng cấu hình..."
# Cập nhật danh sách restart đúng tên mới
docker restart myst_node_1 myst_node_2 myst_node_3 myst_node_4 myst_node_5 || true

echo "----------------------------------------"
echo "[DONE] Setup 5 node Mysterium hoàn tất ✅"
