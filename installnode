#!/bin/bash
set -e

# ==========================================
# 1. CẤU HÌNH TOKEN (GIỮ NGUYÊN)
# ==========================================
TOKEN_TM="/PfkwR8qQMfbsCMrSaaDhsX96E9w2PeHH2bcGeyFBno="
TOKEN_EARNFM="50f04bbe-94d9-4f6a-82b9-b40016bd4bbb"
TOKEN_REPOCKET_EMAIL="nguyenvinhson000@gmail.com"
TOKEN_REPOCKET_API="cad6dcce-d038-4727-969b-d996ed80d3ef"
USER_UR="nguyenvinhcao123@gmail.com"
PASS_UR="CAOcao123CAO@"

# DNS Cloudflare
DNS_OPTS="--dns 1.1.1.1 --dns 1.0.0.1"

# Interface chính (Debian 12 trên UpCloud thường là eth0)
IFACE="eth0"

# Image
ARCH=$(uname -m)
if [[ "$ARCH" == "aarch64" ]]; then
  IMG_TM="traffmonetizer/cli_v2:arm64v8"
else
  IMG_TM="traffmonetizer/cli_v2:latest"
fi
IMG_MYST="mysteriumnetwork/myst:latest"
IMG_UR="techroy23/docker-urnetwork:latest"
IMG_EARN="earnfm/earnfm-client:latest"
IMG_REPO="repocket/repocket:latest"

# Logger
log() { echo -e "\e[32m[INFO] $1\e[0m"; }
warn() { echo -e "\e[33m[WARN] $1\e[0m"; }
err() { echo -e "\e[31m[ERROR] $1\e[0m"; exit 1; }

# ==========================================
# 2. CHUẨN BỊ DEBIAN
# ==========================================
log "Update hệ thống & cài tools..."
sudo apt-get update -q
sudo apt-get install -y curl net-tools grep iptables iproute2 jq

if ! command -v docker &> /dev/null; then
  log "Cài Docker..."
  curl -fsSL https://get.docker.com | sh
  sudo systemctl enable --now docker
fi

# ==========================================
# 3. LẤY IP TỰ ĐỘNG BẰNG MẢNG (UPCLOUD MULTI-IP)
# ==========================================
log "--- KẾT QUẢ QUÉT IP ---"
# Lấy tất cả IPv4 trên eth0 (bao gồm cả alias) và đưa vào mảng
mapfile -t ALL_IPS < <(ip -o -4 addr show dev $IFACE | awk '{print $4}' | cut -d/ -f1)
TOTAL_IPS=${#ALL_IPS[@]}

if [ "$TOTAL_IPS" -eq 0 ]; then
    err "Không tìm thấy IP nào trên $IFACE!"
fi

log "Đã tìm thấy $TOTAL_IPS IP:"
for i in "${!ALL_IPS[@]}"; do
    log " -> IP $((i+1)): ${ALL_IPS[$i]}"
done

# ==========================================
# 4. NETWORK & SNAT
# ==========================================
if [ -n "$(docker ps -aq)" ]; then docker rm -f $(docker ps -aq) >/dev/null 2>&1; fi
docker network prune -f >/dev/null 2>&1

log "Cấu hình SNAT (IP Masquerade)..."
# Xóa rule cũ
sudo iptables -t nat -F POSTROUTING

# Tạo mạng và Rule SNAT cho từng IP
for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    IP="${ALL_IPS[$i]}"
    NET_NAME="my_network_$INDEX"
    SUBNET="192.168.10${INDEX}.0/24" # Tạo dải mạng tự động: 192.168.101.x, 102.x...

    # Tạo network
    docker network create "$NET_NAME" --driver bridge --subnet "$SUBNET" >/dev/null 2>&1 || true
    
    # Rule SNAT: Ép traffic từ subnet ra đúng source IP
    sudo iptables -t nat -I POSTROUTING -s "$SUBNET" -j SNAT --to-source "$IP"
done

sleep 2

# ==========================================
# 5. CHECK IP OUTPUT (KIỂM TRA THỰC TẾ)
# ==========================================
get_public_ip() {
    docker run --rm --network "$1" $DNS_OPTS curlimages/curl:latest -s --max-time 10 https://api.ipify.org || echo "LỖI_MẠNG"
}

log "🕵️ Check IP Public đầu ra..."
for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    EXPECTED_IP="${ALL_IPS[$i]}"
    ACTUAL_IP=$(get_public_ip "my_network_$INDEX")
    
    if [ "$ACTUAL_IP" == "$EXPECTED_IP" ]; then
        log "👉 Node $INDEX (IP $EXPECTED_IP) -> Public: $ACTUAL_IP (CHUẨN)"
    else
        warn "⚠️ Node $INDEX: LỆCH IP! (Máy xuất ra: $ACTUAL_IP)"
    fi
done

# ==========================================
# 6. KHỞI CHẠY NODE
# ==========================================
log "🚀 Start Nodes..."

run_nodes() {
    # Thêm biến INDEX để xác định số thứ tự cho volume Mysterium
    local INDEX=$1
    local NET=$2
    local BIND_IP=$3
    local SUFFIX=$4
    
    # Traffmonetizer
    docker run -d --network $NET --restart always --name tm_$SUFFIX $DNS_OPTS \
      $IMG_TM start accept --token "$TOKEN_TM" >/dev/null

    # Mysterium (Dùng volume cố định myst-data1 / myst-data2...)
    docker run -d --network $NET --cap-add NET_ADMIN $DNS_OPTS \
      -p ${BIND_IP}:4449:4449 \
      --name myst_$SUFFIX -v myst-data${INDEX}:/var/lib/mysterium-node \
      --restart unless-stopped $IMG_MYST service --agreed-terms-and-conditions >/dev/null

    # UrNetwork
    docker run -d --network $NET --restart always --cap-add NET_ADMIN $DNS_OPTS \
      --name ur_$SUFFIX -v ur_data_$SUFFIX:/var/lib/vnstat \
      -e USER_AUTH="$USER_UR" -e PASSWORD="$PASS_UR" $IMG_UR >/dev/null

    # EarnFM
    docker run -d --network $NET --restart always $DNS_OPTS \
      -e EARNFM_TOKEN="$TOKEN_EARNFM" --name earn_$SUFFIX $IMG_EARN >/dev/null

    # Repocket
    docker run -d --network $NET --restart always $DNS_OPTS \
      --name rp_$SUFFIX \
      -e RP_EMAIL="$TOKEN_REPOCKET_EMAIL" -e RP_API_KEY="$TOKEN_REPOCKET_API" $IMG_REPO >/dev/null
}

# Lặp qua tất cả IP để chạy Nodes
for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    run_nodes "$INDEX" "my_network_$INDEX" "${ALL_IPS[$i]}" "node_$INDEX"
done

log "==== DONE ===="
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
