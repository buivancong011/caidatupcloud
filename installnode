#!/bin/bash
set -e

# ==========================================
# 1. CẤU HÌNH TOKEN & TÀI KHOẢN
# ==========================================
TOKEN_TM="/PfkwR8qQMfbsCMrSaaDhsX96E9w2PeHH2bcGeyFBno="
TOKEN_EARNFM="50f04bbe-94d9-4f6a-82b9-b40016bd4bbb"
TOKEN_REPOCKET_EMAIL="nguyenvinhson000@gmail.com"
TOKEN_REPOCKET_API="cad6dcce-d038-4727-969b-d996ed80d3ef"
USER_UR="nguyenvinhcao123@gmail.com"
PASS_UR="CAOcao123CAO@"

# ==== CẤU HÌNH BITPING ====
EMAIL_BITPING="nguyenvinhcao123@gmail.com"
PASS_BITPING="nguyenvinhcao123@gmail.com"

# ==== CẤU HÌNH TỐI ƯU DOCKER ====
DNS_OPTS="--dns 1.1.1.1 --dns 1.0.0.1"
LOG_OPTS="--log-opt max-size=10m --log-opt max-file=3"

log() { echo -e "\e[32m[INFO] $1\e[0m"; }
warn() { echo -e "\e[33m[WARN] $1\e[0m"; }
err() { echo -e "\e[31m[ERROR] $1\e[0m"; exit 1; }

# ==========================================
# CHỐT CHẶN 0: KIỂM TRA MẠNG TỔNG
# ==========================================
log "Kiểm tra kết nối Internet sơ bộ..."
if ! curl -s --connect-timeout 5 https://1.1.1.1 > /dev/null; then
    err "VPS không có Internet! Dừng script ngay để bảo vệ hệ thống."
fi

# ==========================================
# 2. CHỌN IMAGE & CHUẨN BỊ HỆ THỐNG
# ==========================================
log "🔍 Đang kiểm tra kiến trúc CPU..."
ARCH=$(uname -m)

log "⚙️  Đang cài đặt công cụ bổ trợ (jq, curl, iptables)..."
export DEBIAN_FRONTEND=noninteractive
sudo apt-get update -qq && sudo apt-get install -y -q curl jq coreutils iproute2 iptables >/dev/null 2>&1 || true

if ! command -v docker &> /dev/null; then
    log "🐳 Đang cài đặt Docker..."
    curl -fsSL https://get.docker.com | sh >/dev/null 2>&1
    sudo systemctl enable --now docker
fi

# Tối ưu mạng & Swap
log "🚀 Tối ưu BBR và cấu hình Swap 2GB..."
sudo tee /etc/sysctl.d/99-mmo-node-tuning.conf >/dev/null <<EOF
net.core.rmem_max=4194304
net.core.wmem_max=4194304
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
vm.swappiness=10
EOF
sudo sysctl -p /etc/sysctl.d/99-mmo-node-tuning.conf >/dev/null 2>&1 || true

if [ ! -f /swapfile ]; then
    sudo dd if=/dev/zero of=/swapfile bs=1M count=2048 status=none
    sudo chmod 600 /swapfile
    sudo mkswap /swapfile >/dev/null 2>&1
    sudo swapon /swapfile >/dev/null 2>&1
    echo '/swapfile none swap sw 0 0' | sudo tee -a /etc/fstab >/dev/null
fi

# ==========================================
# 3. DÒ TÌM VÀ THIẾT LẬP ĐA IP (UPCLOUD)
# ==========================================
log "📡 Đang dò tìm danh sách IP trên Interface..."
MAIN_IFACE=$(ip route show default | awk '/default/ {print $5}' | head -n 1)
mapfile -t ALL_IPS < <(ip -4 addr show dev $MAIN_IFACE | grep -w inet | awk '{print $2}' | cut -d/ -f1)
TOTAL_IPS=${#ALL_IPS[@]}

if [ "$TOTAL_IPS" -eq 0 ]; then
    err "LỖI: Không tìm thấy bất kỳ IP nào trên $MAIN_IFACE!"
fi

log "Dọn dẹp container & network cũ..."
[ -n "$(docker ps -aq)" ] && docker rm -f $(docker ps -aq) >/dev/null 2>&1
docker network prune -f >/dev/null 2>&1
sudo iptables-save | grep -v "192.168.10" | sudo iptables-restore

log "🏗️  Đang thiết lập $TOTAL_IPS luồng mạng riêng biệt..."
for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    IP="${ALL_IPS[$i]}"
    NET_NAME="my_network_$INDEX"
    SUBNET="192.168.10${INDEX}.0/24"
    docker network create "$NET_NAME" --driver bridge --subnet "$SUBNET" >/dev/null 2>&1 || true
    sudo iptables -t nat -I POSTROUTING -s "$SUBNET" -j SNAT --to-source "$IP"
done

log "⏳ Chờ 5s cập nhật bảng định tuyến..."
sleep 5

# ==========================================
# 4. CHỐT CHẶN: XÁC THỰC IP PUBLIC THỰC TẾ
# ==========================================
log "🕵️ Đang xác thực IP Public cho từng luồng..."
for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    SRC_IP="${ALL_IPS[$i]}"
    EXIT_IP=$(docker run --rm --network "my_network_$INDEX" curlimages/curl:latest -s --max-time 10 https://api.ipify.org || echo "FAIL")
    
    if [ "$EXIT_IP" == "FAIL" ]; then
        err "❌ Cụm $INDEX (Local IP: $SRC_IP) MẤT MẠNG INTERNET! Dừng kịch bản ngay."
    fi
    
    log "   Check $INDEX: Source $SRC_IP -> Exit: [$EXIT_IP]"
done

# ==========================================
# 5. KHỞI CHẠY NODES (CÓ BỌC GIÁP LOG 10MB)
# ==========================================
log "🚀 Đang Pull images song song..."
for img in "traffmonetizer/cli_v2:latest" "mysteriumnetwork/myst:latest" "techroy23/docker-urnetwork:latest" "earnfm/earnfm-client:latest" "repocket/repocket:latest" "bitping/bitpingd:latest"; do
    docker pull $img >/dev/null 2>&1 &
done
wait

run_nodes() {
    local INDEX=$1; local NET=$2; local BIND_IP=$3; local SUFFIX=$4
    
    # Traffmonetizer
    docker run -d --network $NET --restart always $LOG_OPTS --name tm_$SUFFIX $DNS_OPTS traffmonetizer/cli_v2:latest start accept --token "$TOKEN_TM" >/dev/null
    
    # Mysterium
    docker run -d --network $NET --cap-add NET_ADMIN $LOG_OPTS $DNS_OPTS -p ${BIND_IP}:4449:4449 --name myst_$SUFFIX -v myst-data${INDEX}:/var/lib/mysterium-node --restart unless-stopped mysteriumnetwork/myst:latest service --agreed-terms-and-conditions >/dev/null
    
    # UrNetwork
    docker run -d --network $NET --restart always --cap-add NET_ADMIN $LOG_OPTS $DNS_OPTS --name ur_$SUFFIX -v ur_data_$SUFFIX:/var/lib/vnstat -e USER_AUTH="$USER_UR" -e PASSWORD="$PASS_UR" techroy23/docker-urnetwork:latest >/dev/null
    
    # EarnFM
    docker run -d --network $NET --restart always $LOG_OPTS $DNS_OPTS -e EARNFM_TOKEN="$TOKEN_EARNFM" --name earn_$SUFFIX earnfm/earnfm-client:latest >/dev/null
    
    # Repocket
    docker run -d --network $NET --restart always $LOG_OPTS $DNS_OPTS --name rp_$SUFFIX -e RP_EMAIL="$TOKEN_REPOCKET_EMAIL" -e RP_API_KEY="$TOKEN_REPOCKET_API" repocket/repocket:latest >/dev/null

    # Bitping
    docker run -d --network $NET --restart unless-stopped $LOG_OPTS $DNS_OPTS --name bitping_$SUFFIX -v bitping_data_${INDEX}:/root/.bitpingd -e BITPING_EMAIL="$EMAIL_BITPING" -e BITPING_PASSWORD="$PASS_BITPING" bitping/bitpingd:latest >/dev/null
}

log "🏗️  Đang khởi chạy $TOTAL_IPS cụm Nodes..."
for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    run_nodes "$INDEX" "my_network_$INDEX" "${ALL_IPS[$i]}" "node_$INDEX"
done

log "==== DONE STARTING CONTAINERS - Vinh Cao ===="
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
