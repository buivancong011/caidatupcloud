#!/bin/bash
set -e

echo "[1/3] Đang tạo Script định tuyến động tại /root/yandex_multi_ip.sh..."

cat << 'EOF' > /root/yandex_multi_ip.sh
#!/bin/bash

# 1. Bật tất cả các card mạng phụ (từ eth1 đến eth15) và xin cấp IP
for i in {1..15}; do 
    ip link set eth$i up 2>/dev/null || true
    dhclient eth$i 2>/dev/null || true
done

# Chờ 3 giây để hệ điều hành nhận diện IP xong
sleep 3

# 2. Xóa các cấu hình NAT cũ để tránh xung đột nếu chạy lại nhiều lần
iptables -t nat -F POSTROUTING 2>/dev/null || true

# 3. Quét toàn bộ IP và thiết lập Policy Routing & SNAT
mapfile -t ALL_IPS < <(ip -o -4 addr show | grep ' eth' | grep -w inet | awk '{print $4}' | cut -d/ -f1)

for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    IP="${ALL_IPS[$i]}"
    SUBNET="192.168.10${INDEX}.0/24"
    TABLE_ID=$((INDEX + 200))
    
    # Tự động dò Gateway của từng card
    IFACE=$(ip -o -4 addr show | grep -w "$IP" | awk '{print $2}')
    GW=$(ip -4 route show dev "$IFACE" scope link | grep -oP '^[0-9.]+' | head -n1 | sed 's/\.[0-9]\+$/.1/')
    
    # Thiết lập Rule ép đường đi (Dữ liệu từ subnet nào thì ra đúng card mạng đó)
    ip route add default via "$GW" dev "$IFACE" table "$TABLE_ID" 2>/dev/null || true
    ip rule add from "$SUBNET" table "$TABLE_ID" 2>/dev/null || true
    
    # Thiết lập NAT (Đổi IP nguồn thành IP của card mạng)
    iptables -t nat -I POSTROUTING -s "$SUBNET" -j SNAT --to-source "$IP" 2>/dev/null || true
done
EOF

# Cấp quyền thực thi
chmod +x /root/yandex_multi_ip.sh

echo "[2/3] Đang tạo Systemd Service để tự chạy khi Reboot..."

cat << 'EOF' > /etc/systemd/system/yandex-routing.service
[Unit]
Description=Yandex Cloud Multi-IP Routing Service
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/root/yandex_multi_ip.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

echo "[3/3] Đang kích hoạt Service vĩnh viễn..."

systemctl daemon-reload
systemctl enable yandex-routing.service
systemctl restart yandex-routing.service

echo "🎉 HOÀN TẤT! Cấu hình mạng đã được lưu."
echo "Bây giờ bạn có thể Reboot máy thoải mái, VPS sẽ luôn tự động nhận đủ card mạng và phân luồng chuẩn xác!"
