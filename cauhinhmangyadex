#!/bin/bash
set -e

echo "[1/3] Đang tạo Script mạng tự động (Mô phỏng bản thủ công)..."

cat << 'EOF' > /root/multi_ip_auto.sh
#!/bin/bash

# 1. Tìm card mạng chính (thường là eth0) để né nó ra, bảo vệ mạng tổng
MAIN_IFACE=$(ip route show default main | awk '/default/ {print $5}' | head -n 1)

# Lấy danh sách các card mạng phụ (ví dụ: eth1, eth2...)
SEC_IFACES=$(ls /sys/class/net | grep -E "^eth|^ens|^enp" | grep -v "lo" | grep -v "$MAIN_IFACE")

echo "1. Đang bật và xin cấp IP cho các card mạng phụ..."
for iface in $SEC_IFACES; do
    ip link set $iface up 2>/dev/null || true
    dhclient $iface 2>/dev/null || true
done

# Đợi 3 giây để hệ thống nhận IP xong xuôi
sleep 3

echo "2. Đang tự động cấu hình Rule định tuyến giống bản thủ công..."
TABLE_ID=101

for iface in $SEC_IFACES; do
    # Lấy IP của card mạng hiện tại
    IP=$(ip -o -4 addr show dev $iface | awk '{print $4}' | cut -d/ -f1 | head -n 1)
    
    # Bỏ qua nếu card này chưa nhận được IP
    if [ -z "$IP" ]; then continue; fi
    
    # Tự động tính Gateway của Yandex (Lấy 3 số đầu ghép với .1)
    GW=$(echo "$IP" | awk -F. '{print $1"."$2"."$3".1"}')
    
    echo " -> Đã nhận: Card $iface | IP: $IP | Gateway: $GW | Table: $TABLE_ID"
    
    # Xoá rule cũ (nếu chạy lại nhiều lần) để tránh lỗi
    ip route flush table $TABLE_ID 2>/dev/null || true
    
    # 3 lệnh cốt lõi giống y hệt bản gõ tay của bạn:
    ip route add default via $GW dev $iface table $TABLE_ID 2>/dev/null || true
    ip rule add from $IP/32 table $TABLE_ID 2>/dev/null || true
    ip rule add to $IP/32 table $TABLE_ID 2>/dev/null || true
    
    # Tăng ID bảng định tuyến cho card tiếp theo (101, 102, 103...)
    TABLE_ID=$((TABLE_ID + 1))
done
EOF

chmod +x /root/multi_ip_auto.sh

echo "[2/3] Đang tạo Systemd Service để chạy ngầm lúc Reboot..."
cat << 'EOF' > /etc/systemd/system/multi-ip-auto.service
[Unit]
Description=Auto Setup Multi-IP Routing for Yandex Cloud
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/root/multi_ip_auto.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

echo "[3/3] Đang kích hoạt chạy vĩnh viễn..."
systemctl daemon-reload
systemctl enable multi-ip-auto.service
systemctl restart multi-ip-auto.service

echo "🎉 HOÀN TẤT! Từ nay bạn tạo VPS mới, cắm bao nhiêu IP thì script này cũng tự động làm ra bộ Rule chuẩn xác như bạn tự gõ tay!"
