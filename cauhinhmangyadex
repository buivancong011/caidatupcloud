#!/bin/bash
set -e

echo "[1/3] Đang tạo Script định tuyến an toàn tại /root/yandex_multi_ip.sh..."

cat << 'EOF' > /root/yandex_multi_ip.sh
#!/bin/bash

# 1. Tìm card mạng chính đang giữ kết nối Internet gốc
MAIN_IFACE=$(ip route show default main | awk '/default/ {print $5}' | head -n 1)
echo "Card mạng chính là: $MAIN_IFACE. Sẽ đưa vào vùng an toàn (Bỏ qua dhclient)."

# Lấy danh sách các card mạng phụ (Bỏ qua 'lo' và 'Card chính')
SECONDARY_IFACES=$(ls /sys/class/net | grep -v "lo" | grep -v "$MAIN_IFACE")

echo "2. Đang bật các card mạng phụ..."
for iface in $SECONDARY_IFACES; do
    ip link set $iface up 2>/dev/null || true
    # Chỉ chạy cấp IP (dhclient) cho card phụ để tránh chết mạng tổng
    dhclient $iface 2>/dev/null || true
done

sleep 3
iptables -t nat -F POSTROUTING 2>/dev/null || true

echo "3. Đang phân luồng định tuyến (Policy Routing)..."
mapfile -t ALL_IPS < <(ip -o -4 addr show | awk '$2 != "lo" {print $4}' | cut -d/ -f1)

for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    IP="${ALL_IPS[$i]}"
    SUBNET="192.168.10${INDEX}.0/24"
    TABLE_ID=$((INDEX + 200))
    
    IFACE=$(ip -o -4 addr show | awk -v ip="$IP" '$4 ~ ip {print $2}')
    GW=$(echo "$IP" | awk -F. '{print $1"."$2"."$3".1"}')
    
    echo " -> Đang cấu hình IP: $IP (Card: $IFACE)"
    
    # CHỈ ép đường đi (Policy Route) cho các card phụ
    if [ "$IFACE" != "$MAIN_IFACE" ]; then
        ip route flush table "$TABLE_ID" 2>/dev/null || true
        ip route add default via "$GW" dev "$IFACE" table "$TABLE_ID" 2>/dev/null || true
        ip rule add from "$SUBNET" table "$TABLE_ID" 2>/dev/null || true
    fi
    
    # Thiết lập NAT cho Docker
    iptables -t nat -I POSTROUTING -s "$SUBNET" -j SNAT --to-source "$IP" 2>/dev/null || true
done
EOF

chmod +x /root/yandex_multi_ip.sh

echo "[2/3] Đang tạo Systemd Service chạy ngầm..."
cat << 'EOF' > /etc/systemd/system/yandex-routing.service
[Unit]
Description=Yandex Cloud Multi-IP Routing Service (Safe Mode)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/root/yandex_multi_ip.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

echo "[3/3] Đang kích hoạt tự động chạy khi Reboot..."
systemctl daemon-reload
systemctl enable yandex-routing.service
systemctl start yandex-routing.service

echo "🎉 HOÀN TẤT! Cấu hình an toàn đã được kích hoạt. Bạn có thể gõ 'reboot' để test thoải mái!"
