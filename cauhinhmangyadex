#!/bin/bash
set -e

echo "Đang tạo cấu hình mạng thuần túy (Chỉ nhận IP và mở kết nối)..."

cat << 'EOF' > /root/yandex_network_only.sh
#!/bin/bash

# 1. Chống nhiễu địa chỉ MAC (Bắt buộc khi cắm nhiều card mạng)
sysctl -w net.ipv4.conf.all.arp_ignore=1 >/dev/null 2>&1
sysctl -w net.ipv4.conf.all.arp_announce=2 >/dev/null 2>&1

# Lấy tên card mạng chính (tránh đụng chạm gây rớt mạng tổng)
MAIN_IFACE=$(ip route show default main | awk '/default/ {print $5}' | head -n 1)

# 2. Bật tất cả các card mạng phụ và xin IP
SECONDARY_IFACES=$(ls /sys/class/net | grep -E "^eth|^ens|^enp" | grep -v "lo" | grep -v "$MAIN_IFACE")
for iface in $SECONDARY_IFACES; do
    ip link set $iface up 2>/dev/null || true
    dhclient $iface 2>/dev/null || true
done
sleep 3

# 3. Mở đường kết nối cho từng IP (Policy Routing)
mapfile -t ALL_IPS < <(ip -o -4 addr show | grep -E "eth|ens|enp" | awk '$2 != "lo" {print $4}' | cut -d/ -f1)

for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    IP="${ALL_IPS[$i]}"
    TABLE_ID=$((INDEX + 200))
    
    # Tìm tên card và tự động tính Gateway
    IFACE=$(ip -o -4 addr show | awk -v ip="$IP" '$4 ~ ip {print $2}')
    GW=$(echo "$IP" | awk -F. '{print $1"."$2"."$3".1"}')
    
    # Nếu là card phụ, thiết lập rule bắt buộc trả lời đúng cửa
    if [ "$IFACE" != "$MAIN_IFACE" ]; then
        ip route flush table "$TABLE_ID" 2>/dev/null || true
        ip route add default via "$GW" dev "$IFACE" table "$TABLE_ID" 2>/dev/null || true
        
        # Rule quan trọng nhất: Khách kết nối vào IP nào, VPS phải trả lời bằng IP đó
        ip rule add from "$IP" table "$TABLE_ID" 2>/dev/null || true
    fi
done
EOF

chmod +x /root/yandex_network_only.sh

echo "Đang lưu cấu hình vào Systemd để tự chạy khi khởi động lại..."
cat << 'EOF' > /etc/systemd/system/yandex-net.service
[Unit]
Description=Yandex Cloud Basic IP Routing
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/root/yandex_network_only.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable yandex-net.service
systemctl restart yandex-net.service

echo "✅ HOÀN TẤT! Tất cả các IP đã được mở luồng kết nối thành công."
